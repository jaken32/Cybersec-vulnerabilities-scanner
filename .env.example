# websec-scanner configuration. Copy to .env and adjust as needed.
# .env is git-ignored and must never be committed. No secrets are required to run.

# --- Web server ---
# Interface/port are passed to uvicorn on the command line; see the README.

# --- Rate limiting (protects this app and scan targets) ---
# slowapi limit string, e.g. "10/minute", "100/hour".
WEBSEC_RATE_LIMIT=10/minute
# Minimum seconds between scans of the same target URL.
WEBSEC_TARGET_COOLDOWN_SECONDS=30

# --- Scan engine limits (SSRF / DoS hardening) ---
# Per-request timeout in seconds.
WEBSEC_SCAN_TIMEOUT=12
# Maximum bytes read from a target response.
WEBSEC_MAX_RESPONSE_BYTES=5242880

# --- Response hardening ---
# Send HSTS on our own responses. Keep "true" in production (HTTPS).
# Set "false" only for plain-HTTP local development.
WEBSEC_ENABLE_HSTS=true

# --- Result cache ---
# Seconds a generated report stays downloadable.
WEBSEC_RESULT_TTL_SECONDS=1800

# --- Logging ---
WEBSEC_LOG_LEVEL=INFO
